---
const { selectedItem } = Astro.props;

import ContactIcon from "./ContactIcon.astro";

const navItems = [
  { key: "home", href: "/", icon: "/assets/home.svg", label: "Home" },
  {
    key: "experience",
    href: "/experience",
    icon: "/assets/code.svg",
    label: "Experience",
  },
  { key: "devops", href: "/devops", icon: "/assets/dns.svg", label: "DevOps" },
  {
    key: "contact",
    href: "/contact",
    icon: "/assets/chat.svg",
    label: "Contact Me",
  },
];
---

<aside
  data-animation="default"
  data-collapse="medium"
  data-duration="400"
  data-easing="ease"
  data-easing2="ease"
  role="banner"
  class="sidebar w-nav"
>
  <div class="nav-content">
    <div class="brand-block">
      <a href="/" class="w-nav-brand" aria-label="home">
        <div class="niv-data">
          <img
            src="/assets/profile.jpg"
            loading="eager"
            fetchpriority="high"
            width="1024"
            height="1024"
            alt="Leejay Hsu"
            class="niv-image"
          />
          <div>
            <div class="label-white">Leejay Hsu</div>
            <div class="label-gray">Software Engineer</div>
          </div>
        </div>
      </a>
      <div class="sidebar-link-row" aria-label="Contact links">
        <a
          href="mailto:leejayhsu@gmail.com"
          class="sidebar-icon-link"
          aria-label="Email"
          style="--tooltip-anchor: --sidebar-email-tooltip;"
        >
          <ContactIcon name="email" />
          <span class="contact-tooltip" aria-hidden="true">Email</span>
        </a>
        <a
          href="/assets/resume.pdf"
          class="sidebar-icon-link"
          type="application/pdf"
          download="Leejay-Hsu-Resume.pdf"
          aria-label="Download resume PDF"
          style="--tooltip-anchor: --sidebar-resume-tooltip;"
        >
          <ContactIcon name="attachment" />
          <span class="contact-tooltip" aria-hidden="true">Resume PDF</span>
        </a>
        <a
          href="https://github.com/leejayhsu"
          class="sidebar-icon-link"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
          style="--tooltip-anchor: --sidebar-github-tooltip;"
        >
          <img
            src="/assets/github.svg"
            width="24"
            height="24"
            decoding="async"
            alt=""
          />
          <span class="contact-tooltip" aria-hidden="true">GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/leejayhsu"
          class="sidebar-icon-link"
          aria-label="LinkedIn"
          target="_blank"
          rel="noopener noreferrer"
          style="--tooltip-anchor: --sidebar-linkedin-tooltip;"
        >
          <img
            src="/assets/linkedin.svg"
            width="24"
            height="24"
            decoding="async"
            alt=""
          />
          <span class="contact-tooltip" aria-hidden="true">LinkedIn</span>
        </a>
      </div>
    </div>

    <nav
      role="navigation"
      class="w-nav-menu desktop-nav-menu"
      aria-label="Main navigation"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link-container w-inline-block ${
              selectedItem === item.key ? "w--current" : ""
            }`}
            aria-current={selectedItem === item.key ? "page" : undefined}
          >
            <img
              src={item.icon}
              loading="eager"
              width="24"
              height="24"
              alt=""
              class="nav-link-image"
            />
            <div>{item.label}</div>
          </a>
        ))
      }
    </nav>

    <nav
      role="navigation"
      class="w-nav-menu mobile-nav-menu"
      id="mobile-nav-menu"
      popover="auto"
      aria-label="Mobile navigation"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link-container w-inline-block ${
              selectedItem === item.key ? "w--current" : ""
            }`}
            aria-current={selectedItem === item.key ? "page" : undefined}
          >
            <img
              src={item.icon}
              loading="eager"
              width="24"
              height="24"
              alt=""
              class="nav-link-image"
            />
            <div>{item.label}</div>
          </a>
        ))
      }
    </nav>

    <button
      type="button"
      class="navbar-icon-button w-nav-button"
      style="-webkit-user-select: text;"
      aria-label="menu"
      popovertarget="mobile-nav-menu"
    >
      <img
        src="/assets/menu.svg"
        loading="eager"
        width="40"
        height="40"
        alt=""
        class="navbar-icon"
      />
    </button>
  </div>
</aside>
