---
interface Props {
  title: string;
  role?: string;
  period?: string;
  desc: string[];
  tech: string[];
  href: string;
  timeline?: boolean;
}

const { title, role, period, desc, tech, href, timeline = false } = Astro.props;

const toDateTime = (date: string) => {
  const [month, year] = date.split("/");
  return year && month ? `${year}-${month}` : undefined;
};

const [periodStart, periodEnd] = period?.split(" - ") ?? [];
---

<div class={`single-item${timeline ? " timeline-item" : ""}`}>
  {
    timeline && period && (
      <div class="timeline-date" aria-label={period}>
        {periodStart && (
          <time datetime={toDateTime(periodStart)}>{periodStart}</time>
        )}
        {periodStart && periodEnd && (
          <span class="date-range-marker" aria-hidden="true">
            <svg viewBox="0 0 12 14" focusable="false">
              <path d="M6 12V2M2.5 5.5 6 2l3.5 3.5" />
            </svg>
          </span>
        )}
        {periodEnd &&
          (toDateTime(periodEnd) ? (
            <time datetime={toDateTime(periodEnd)}>{periodEnd}</time>
          ) : (
            <span>{periodEnd}</span>
          ))}
      </div>
    )
  }
  {
    timeline && (
      <div class="timeline-marker" aria-hidden="true">
        <span />
      </div>
    )
  }
  <div class="project-content">
    <h3 class="project-title">
      <a
        href={href}
        class="text-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        {title}
      </a>
    </h3>
    {
      (role || period) && (
        <p class="project-meta">
          {role && <span>{role}</span>}
          {!timeline && role && period && <span aria-hidden="true"> · </span>}
          {!timeline && periodStart && (
            <>
              <time datetime={toDateTime(periodStart)}>{periodStart}</time>
              {periodEnd && (
                <>
                  {" - "}
                  {toDateTime(periodEnd) ? (
                    <time datetime={toDateTime(periodEnd)}>{periodEnd}</time>
                  ) : (
                    <span>{periodEnd}</span>
                  )}
                </>
              )}
            </>
          )}
        </p>
      )
    }
    <div class="project-desc project-desc-list w-richtext">
      <ul>
        {desc.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="mini-label-white">Technologies &amp; tools</div>
    <ul class="chips-container">
      {tech.map((techItem) => <li class="single-chip">{techItem}</li>)}
    </ul>
  </div>
</div>
