---
import Header from "../components/Header.astro";
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
const projects = [
  {
    title: "Tensec",
    desc: [
      "Architected and deployed containerized infrastructure on AWS ECS, enabling scalable application hosting",
      "Implemented CI/CD pipelines in GitHub Actions, automating deployments and reducing release times by 50%",
      "Improved code quality and developer velocity by implementing AI-powered automated code reviews",
    ],
    tech: ["Terraform", "AWS", "Docker", "Github Actions"],
    href: "https://www.tensec.io",
  },
];
---

<!doctype html>
<html lang="en">
  <Header title="DevOps | Leejay Hsu" />
  <body>
    <div class="content">
      <Sidebar selectedItem="devops" />
      <main class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img
                src="/assets/back.svg"
                loading="lazy"
                width="24"
                height="24"
                decoding="async"
                alt=""
                class="back-nav-img"
              />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>DevOps</h1>
            <section class="items-container">
              <div class="resouce-items">
                {
                  projects.map((project) => (
                    <Project
                      title={project.title}
                      desc={project.desc}
                      tech={project.tech}
                      href={project.href}
                    />
                  ))
                }
              </div>
            </section>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
