---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import ContactIcon from "../components/ContactIcon.astro";
---

<!doctype html>
<html lang="en">
  <Header title="Leejay Hsu" />
  <body>
    <div class="content">
      <Sidebar selectedItem="home" />
      <main class="main">
        <div class="container">
          <section
            class="fold-content-container"
            aria-labelledby="intro-heading"
          >
            <div class="fold-content">
              <h1 id="intro-heading">Hi, I'm Leejay 👋</h1>
              <p class="lead">
                Experienced fullstack developer with DevOps expertise, currently
                building agentic features in fintech.
              </p>
            </div>
            <div class="link-row">
              <a
                href="mailto:leejayhsu@gmail.com"
                class="icon-link"
                aria-label="Email"
                data-tooltip="Email"
              >
                <ContactIcon name="email" />
              </a>
              <a
                href="/assets/resume.pdf"
                class="icon-link"
                type="application/pdf"
                download="Leejay-Hsu-Resume.pdf"
                aria-label="Download resume PDF"
                data-tooltip="Resume PDF"
              >
                <ContactIcon name="attachment" />
              </a>
              <a
                href="https://github.com/leejayhsu"
                class="icon-link"
                aria-label="GitHub"
                data-tooltip="GitHub"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src="/assets/github.svg"
                  width="24"
                  height="24"
                  decoding="async"
                  alt=""
                />
              </a>
              <a
                href="https://www.linkedin.com/in/leejayhsu"
                class="icon-link"
                aria-label="LinkedIn"
                data-tooltip="LinkedIn"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src="/assets/linkedin.svg"
                  width="24"
                  height="24"
                  decoding="async"
                  alt=""
                />
              </a>
            </div>
          </section>
          <div class="projects-section">
            <!-- Software Development -->
            <a href="/experience" class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img
                    src="/assets/browser.svg"
                    loading="lazy"
                    width="48"
                    height="48"
                    decoding="async"
                    alt=""
                    class="projects-category-image"
                  />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Experience</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">
                    Technologies &amp; tools
                  </div>
                  <ul class="chips-container chips-container-small-width">
                    <li class="single-chip small-chip">Python</li>
                    <li class="single-chip small-chip">TypeScript</li>
                    <li class="single-chip small-chip">FastAPI</li>
                    <li class="single-chip small-chip">Next.js</li>
                    <li class="single-chip small-chip">React</li>
                    <li class="single-chip small-chip">NestJS</li>
                    <li class="single-chip small-chip">Django</li>
                    <li class="single-chip small-chip">Postgres</li>
                  </ul>
                </div>
              </div>
            </a>
            <!-- DevOps & Cloud -->
            <a href="/devops" class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container devops-img">
                  <img
                    src="/assets/database.svg"
                    loading="lazy"
                    width="48"
                    height="48"
                    decoding="async"
                    alt=""
                    class="projects-category-image"
                  />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>DevOps</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">
                    Technologies &amp; tools
                  </div>
                  <ul class="chips-container chips-container-small-width">
                    <li class="single-chip small-chip">AWS</li>
                    <li class="single-chip small-chip">Terraform</li>
                    <li class="single-chip small-chip">Docker</li>
                    <li class="single-chip small-chip">Linux</li>
                    <li class="single-chip small-chip">Bash</li>
                  </ul>
                </div>
              </div>
            </a>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
