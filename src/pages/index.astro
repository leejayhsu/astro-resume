---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
---

<!doctype html>
<html lang="en">
  <Header title="Leejay Hsu" />
  <body>
    <div class="content">
      <Sidebar selectedItem="home" />
      <nav class="main">
        <div class="container">
          <main class="fold-content-container">
            <div class="fold-content">
              <h1>Hi, I'm Leejay 👋</h1>
              <p class="lead">
                Experienced fullstack developer with DevOps expertise, currently
                building agentic features in fintech.
              </p>
            </div>
            <a href="mailto:leejayhsu@gmail.com	" class="button w-button"
              >Contact</a
            >
          </main>
          <div class="projects-section">
            <!-- Software Development -->
            <a href="/experience" class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img
                    src="./assets/browser.svg"
                    loading="lazy"
                    alt=""
                    class="projects-category-image"
                  />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Professional Experience</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">
                    Technologies &amp; tools
                  </div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">Python</div>
                    <div class="single-chip small-chip">TypeScript</div>
                    <div class="single-chip small-chip">FastAPI</div>
                    <div class="single-chip small-chip">Next.js</div>
                    <div class="single-chip small-chip">React</div>
                    <div class="single-chip small-chip">NestJS</div>
                    <div class="single-chip small-chip">Django</div>
                    <div class="single-chip small-chip">Postgres</div>
                  </div>
                </div>
              </div>
            </a>
            <!-- DevOps & Cloud -->
            <a href="/devops" class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container devops-img">
                  <img
                    src="./assets/database.svg"
                    loading="lazy"
                    alt=""
                    class="projects-category-image"
                  />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>DevOps</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">
                    Technologies &amp; tools
                  </div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">AWS</div>
                    <div class="single-chip small-chip">Terraform</div>
                    <div class="single-chip small-chip">Docker</div>
                    <div class="single-chip small-chip">Linux</div>
                    <div class="single-chip small-chip">Bash</div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
